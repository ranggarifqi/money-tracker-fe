# Where the dev server proxies /v1 API requests during `npm run dev`.
# Point this at your running money-tracker backend.
VITE_API_TARGET=http://localhost:8080

# Optional: override the API base URL the app calls directly.
# Defaults to "/v1" (which the dev server proxies to VITE_API_TARGET).
# In production, set this to your deployed API origin if not same-origin,
# e.g. https://api.example.com/v1
# VITE_API_BASE_URL=/v1
